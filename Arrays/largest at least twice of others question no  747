class Solution {
public:
    int dominantIndex(vector<int>& nums) {
        int m = INT_MIN;
        int k ;
        for(int i = 0 ; i < nums.size() ; i++){
            if(nums[i] > m ){
                m = nums[i];
                k = i;
            }
        }
        for(int i = 0 ; i < nums.size() ; i++){
            if(nums[i] > m / 2 && i != k)
            return -1 ;
        }
        return k ;
    }
};
