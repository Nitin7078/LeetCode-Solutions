class Solution {
public:
    double trimMean(vector<int>& arr) {
        sort(arr.begin(), arr.end());
        double sum = 0 ;
        int start = 5 * arr.size() / 100;
        int  end = 5 * arr.size() / 100;
        int c = 0;
        for(int i = start ; i < arr.size()-end ;i++){
            sum += arr[i];
            c++;
        }
        return sum / c;
    }
};
