class Solution {
public:
    double average(vector<int>& salary) {
        sort(salary.begin(),salary.end());
        double sum = 0 ;
        int c = 0;
        for(int i = 1; i < salary.size()-1 ; i++){
            while(salary[i] == salary[0] || salary[i] == salary[salary.size()-1] ){
                continue;
                i++;
            }
            sum = sum + salary[i];
            c++;
        }
        return sum / c;
    }
};
