class Solution {
public:
    bool isPerfectSquare(int num) {
        int low = 0;
        int high = num/2 +1 ;
        if(num == 0 ){
            return 0 ;
        }
        while(low <= high){
            long long mid = low + (high - low) / 2;
            if(mid * mid == num  && mid != 0){
                return true;
            }
            else if(mid *mid<num){
                low = mid+1;
            }
            else{
                high = mid-1;
            }
        } 
        return false ;
    }
};
