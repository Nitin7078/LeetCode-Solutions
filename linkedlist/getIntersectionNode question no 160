class Solution {
public:
    ListNode *getIntersectionNode(ListNode *headA, ListNode *headB) {
        ListNode *temp1 = headA;
        ListNode *temp2 = headB;
        unordered_set<ListNode*>mp;
        while(temp1 != NULL){
            mp.insert(temp1);
            temp1 = temp1->next;
        }

        while(temp2 != NULL){
        if(mp.find(temp2) != mp.end()){
            return temp2 ;
        }
        else{
            temp2 = temp2->next;
        }
        }
        return NULL;
    }
};
