class Solution {
public:
    char findTheDifference(string s, string t) {
        unordered_map<char,int>m;
        for(int i = 0 ; i < s.length() ; i++){
            m[ s[i] ] ++;
        }
        unordered_map<char,int>m2;
        for(int i = 0 ; i< t.length() ; i++){
            m2[t[i]] ++;
        }
        for(int i = 0 ; i < t.length() ; i ++){
            if(m[t[i]] != m2[t[i]]){
                return t[i] ;
            }
        }
        return true ;
    }
};
